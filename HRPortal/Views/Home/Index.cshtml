@{
    ViewData["Title"] = "Football Operations Portal";
}

<div class="container mt-5">

    <div class="text-center">
        <h1 class="display-3 fw-bold text-primary">
            ⚽ Football Operations Portal
        </h1>

        <p class="lead mt-3">
            Enterprise DevOps Proof of Concept
        </p>

        <hr />

        <h4>Modules</h4>

        <div class="row mt-4">

            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5>👥 Player Management</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5>📅 Fixtures</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5>🏟 Stadiums</h5>
                    </div>
                </div>
            </div>

        </div>

        <div class="row mt-4">

            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5>👨‍⚖ Referees</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5>📊 Reports</h5>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5>⚙ Administration</h5>
                    </div>
                </div>
            </div>

        </div>

        <a class="btn btn-primary btn-lg mt-5">
            Explore Portal
        </a>

    </div>

</div>